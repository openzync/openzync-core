# OpenZync Configuration
OPENZYNC_API_KEY=oz_live_your_key_here
OPENZYNC_BASE_URL=http://localhost:8000

# OpenRouter Configuration (OpenAI-compatible endpoint)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# User Configuration
DEFAULT_USER_EXTERNAL_ID=streamlit-chat-user

# Project Configuration (optional — defaults to "Streamlit Chat")
# PROJECT_NAME=My Chat Project

# Pre-configured project UUID (optional — skips auto-discovery)
# Create a project-scoped API key in the dashboard for session access.
# PROJECT_ID=your-project-uuid-here
