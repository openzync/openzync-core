# ═══════════════════════════════════════════════════════════════════════════
# OpenZync — Environment Variables (BOOTSTRAP ONLY)
# ═══════════════════════════════════════════════════════════════════════════
#
# In this self-bootstrapping deployment, the OpenBao secrets store is the
# sole source of truth for ALL runtime configuration (database URL, Redis
# URL, secret keys, LLM keys, webhook secrets, rate limits, etc.). The
# api and worker services fetch their configuration from OpenBao via the
# OpenBao Agent sidecar at startup.
#
# This file should contain ONLY the bootstrap secrets that are needed
# before OpenBao is reachable — i.e., the secrets that openbao-init
# writes to the system KV at first boot.
#
# For local development, Docker Compose injects these automatically via
# the `?:` syntax in infra/docker-compose.backend.yml. A fresh
# `cp .env.example .env` will fail to start the stack until ALL
# `?:`-marked vars are set — by design (fail-fast).
#
# See infra/docker-compose.backend.yml for the full setup and
# docs/adr/004-self-bootstrapping-postgres.md for the architecture.
# ═══════════════════════════════════════════════════════════════════════════

# ── 1. OpenBao seal key (REQUIRED) ──────────────────────────────────────────
# Dev only — production must use Shamir (5-of-3) or cloud KMS (AWS KMS,
# GCP CKMS, Azure Key Vault). The seal key unlocks OpenBao on every
# startup; if lost, ALL secrets in OpenBao are irrecoverable.
#
# Generate a 64-char hex key (32 bytes):
#   openssl rand -hex 32
#
# Required length: exactly 64 hex characters.
BAO_STATIC_SEAL_KEY=<replace-with-64-char-hex>

# ── 2. Postgres superuser password (REQUIRED on first boot) ─────────────────
# This is the password for the `postgres` superuser inside the
# pgvector/pgvector:pg15 container. It is ONLY used by
# scripts/init_postgres.sh to:
#   (a) connect to the fresh Postgres instance,
#   (b) create the `openzync` database and the two application roles
#       (openzync_migrator, openzync_app),
#   (c) apply GRANTs.
# After first boot, scripts/init_postgres.sh auto-rotates the superuser
# password (32-byte base64) and the original value in this file becomes
# useless. The new superuser password is held in memory only and
# discarded. The new migrator + app passwords are written to OpenBao.
#
# Generate a 32-byte base64 password:
#   openssl rand -base64 32
POSTGRES_PASSWORD=<replace-with-32-byte-base64>

# ── 3. Application secret key (REQUIRED) ────────────────────────────────────
# Used by the api/worker for JWT signing and other cryptographic
# operations. Stored in the OpenBao system secret and rendered to the
# api/worker env file by the OpenBao Agent sidecar. Never logged.
#
# Generate a 48+ char URL-safe secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
OZ_SECRET_KEY=<replace-with-48+-char-url-safe-secret>

# ── 4. Webhook signing secret (REQUIRED) ────────────────────────────────────
# Used by WebhookService to sign outbound webhook payloads (HMAC-SHA256,
# Svix-compatible). Stored in OpenBao, rendered to env by Agent. Never
# logged.
#
# Generate a 32+ char URL-safe secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
OZ_WEBHOOK_SIGNING_SECRET=<replace-with-32+-char-url-safe-secret>
