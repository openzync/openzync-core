# =============================================================================
# OpenZync Environment Variables
# =============================================================================
# Copy this file to `.env` and adjust for your local setup.
#   cp .env.example .env
#
# All variables prefixed with `OZ_` are read by pydantic-settings at startup.
# Non-prefixed vars (OPENAI_API_KEY, etc.) are also supported via alias.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL with asyncpg driver. Replace USER:PASSWORD@HOST:PORT/DB with your own.
OZ_DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/<database>

# ── Redis / Caching ───────────────────────────────────────────────────────────
# Used for: session cache, pub/sub, ARQ background job queue.
OZ_REDIS_URL=redis://localhost:6379/0

# ── Graph Backend ─────────────────────────────────────────────────────────────
# PostgreSQL-native graph backend (default — no external graph DB needed).
# Legacy: set OZ_GRAPH_BACKEND=graphiti to use FalkorDB + Graphiti.
# Disable: set OZ_GRAPH_BACKEND=none to disable graph features entirely.
OZ_GRAPH_BACKEND=postgres

# FalkorDB connection — only required when OZ_GRAPH_BACKEND=graphiti.
# OZ_FALKORDB_URL=redis://localhost:6380/0

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider: ollama | openai | azure | anthropic
OZ_LLM_BACKEND=ollama

# Model name / tag.  Default works with `ollama pull llama3.2:3b`.
OZ_LLM_MODEL=llama3.2:3b

# ── Embeddings ────────────────────────────────────────────────────────────────
# Embedding provider.  Leave empty to reuse OZ_LLM_BACKEND.
OZ_EMBEDDING_BACKEND=

# Embedding model name.  Default works with `ollama pull nomic-embed-text`.
OZ_EMBEDDING_MODEL=nomic-embed-text

# Output dimensionality of the embedding model above.
OZ_EMBEDDING_DIM=768

# ── Context / Memory ──────────────────────────────────────────────────────────
# TTL (seconds) for cached context summaries in Redis.
OZ_CONTEXT_CACHE_TTL=30

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
OZ_SECRET_KEY=<your-secret-key-min-32-chars>

# ── LLM API Keys (optional — backend-dependent) ───────────────────────────────
# Required only if OZ_LLM_BACKEND=openai.
OPENAI_API_KEY=

# Required only if OZ_LLM_BACKEND=azure.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Required only if OZ_LLM_BACKEND=anthropic.
ANTHROPIC_API_KEY=

# Base URL for local Ollama (default works for most setups).
OLLAMA_BASE_URL=http://localhost:11434

# ── HTTP / Server ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
OZ_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Comma-separated allowed Host header values for TrustedHostMiddleware in production.
# In development, '*' is used automatically.
# OZ_HOSTS_ALLOWED=api.openzync.tech,localhost:3000

# ── Environment & Observability ───────────────────────────────────────────────
# Options: development | staging | production
OZ_ENVIRONMENT=development
# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
OZ_LOG_LEVEL=INFO

# ── Concurrency ───────────────────────────────────────────────────────────────
# Maximum worker threads/processes.
OZ_MAX_WORKERS=4

# ── Webhooks ────────────────────────────────────────────────────────────────────
# Secret for HMAC-SHA256 signing of webhook payloads. Min 32 chars.
# OZ_WEBHOOK_SIGNING_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per IP within the defined time window.
OZ_RATE_LIMIT_IP_MAX=10
# Rate-limit window in seconds.
OZ_RATE_LIMIT_WINDOW_SEC=60
