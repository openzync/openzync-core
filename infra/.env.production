# =============================================================================
# OpenZep — Production Environment Template
# =============================================================================
# Copy this file to ../.env (project root) on the VPS and fill in all secrets.
#   cp infra/.env.production .env
#   nano .env
#
# NEVER commit the actual .env file to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (user:password@host:port/database).
# The password here is set when the postgres container is first created.
# If you change it later you must also update the POSTGRES_PASSWORD env on the
# postgres service in docker-compose.yml.
MG_DATABASE_URL=postgresql+asyncpg://openzep:__FILL_IN_DB_PASSWORD__@postgres:5432/openzep

# ── Redis / Caching ───────────────────────────────────────────────────────────
MG_REDIS_URL=redis://redis:6379/0

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 characters.
MG_SECRET_KEY=__FILL_IN_SECRET_KEY__

# ── Environment & Observability ───────────────────────────────────────────────
MG_ENVIRONMENT=production
MG_LOG_LEVEL=INFO

# ── HTTP / Server ─────────────────────────────────────────────────────────────
# Comma-separated allowed origins (your frontend domain).
MG_CORS_ORIGINS=http://175.29.21.47:8000,http://localhost:3000

# Comma-separated allowed Host header values.
MG_HOSTS_ALLOWED=175.29.21.47,localhost

# ── LLM Backend ───────────────────────────────────────────────────────────────
# Options: openai | anthropic | azure | ollama
# MG_LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Leave MG_EMBEDDING_BACKEND empty to reuse the LLM backend.
MG_EMBEDDING_BACKEND=
MG_EMBEDDING_MODEL=nomic-embed-text
MG_EMBEDDING_DIM=768

# ── Graph Backend ─────────────────────────────────────────────────────────────
# Options: postgres | graphiti | none
MG_GRAPH_BACKEND=postgres

# ── Context / Memory ──────────────────────────────────────────────────────────
# TTL (seconds) for cached context summaries in Redis.
MG_CONTEXT_CACHE_TTL=30

# ── Rate Limiting ─────────────────────────────────────────────────────────────
MG_RATE_LIMIT_IP_MAX=60
MG_RATE_LIMIT_WINDOW_SEC=60

# ── JWT ───────────────────────────────────────────────────────────────────────
MG_JWT_ACCESS_TOKEN_TTL_MINUTES=30
MG_JWT_REFRESH_TOKEN_TTL_DAYS=7

# ── Webhooks ──────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret. Must be at least 32 characters.
# MG_WEBHOOK_SIGNING_SECRET=__FILL_IN_WEBHOOK_SECRET__

# ── Prometheus ────────────────────────────────────────────────────────────────
# Point at the Prometheus container when observability profile is enabled.
MG_PROMETHEUS_URL=http://prometheus:9090
