{
  "__inputs": [],
  "__requires": [],
  "title": "OpenZync \u2014 Platform Overview",
  "uid": "openzync-overview",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "utc",
  "editable": true,
  "graphTooltip": 1,
  "tags": [
    "openzync",
    "production"
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate & Error Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineInterpolation": "smooth",
            "fillOpacity": 40
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Error Rate"
            },
            "properties": [
              {
                "id": "custom.stacking.mode",
                "value": "none"
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(openzync_http_requests_total[5m])) by (status)",
          "legendFormat": "{{ status }}",
          "refId": "A"
        },
        {
          "expr": "(sum(rate(openzync_http_requests_total{status=\"5xx\"}[5m])) / sum(rate(openzync_http_requests_total[5m]))) * 100",
          "legendFormat": "Error Rate",
          "refId": "B"
        }
      ],
      "thresholds": [
        {
          "value": 1,
          "color": "red",
          "op": "gt"
        }
      ]
    },
    {
      "id": 2,
      "title": "Context Latency Percentiles",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "p99"
            },
            "properties": [
              {
                "id": "custom.lineWidth",
                "value": 3
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openzync_context_latency_seconds_bucket{type=\"warm\"}[5m])) by (le))",
          "legendFormat": "p50 (warm)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(openzync_context_latency_seconds_bucket{type=\"warm\"}[5m])) by (le))",
          "legendFormat": "p95 (warm)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openzync_context_latency_seconds_bucket{type=\"warm\"}[5m])) by (le))",
          "legendFormat": "p99 (warm)",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openzync_context_latency_seconds_bucket{type=\"cold\"}[5m])) by (le))",
          "legendFormat": "p99 (cold)",
          "refId": "D"
        }
      ],
      "thresholds": [
        {
          "value": 1.0,
          "color": "yellow",
          "op": "gt"
        },
        {
          "value": 2.0,
          "color": "red",
          "op": "gt"
        }
      ]
    },
    {
      "id": 3,
      "title": "Worker Queue Depth",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "openzync_worker_queue_depth{queue_name=\"high\"}",
          "legendFormat": "High Priority",
          "refId": "A"
        },
        {
          "expr": "openzync_worker_queue_depth{queue_name=\"low\"}",
          "legendFormat": "Low Priority",
          "refId": "B"
        }
      ],
      "thresholds": [
        {
          "value": 500,
          "color": "yellow",
          "op": "gt"
        },
        {
          "value": 1000,
          "color": "red",
          "op": "gt"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Token Usage",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(openzync_llm_tokens_total[1d])) by (model)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Graph Node Growth",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "sum(openzync_graph_nodes_total)",
          "legendFormat": "all",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Service Health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "API",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 25
      },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"openzync-api\"}",
          "legendFormat": "API",
          "refId": "A"
        }
      ]
    },
    {
